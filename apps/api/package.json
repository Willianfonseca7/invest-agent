{
  "name": "api",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --target=node20 --outfile=dist/server.js",
    "start": "node dist/server.js"
  },
  "dependencies": {
"cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.0"
  }
}
