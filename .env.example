# API
PORT=3001
NODE_ENV=development

# Upstash Redis (producao)
# Obter em: https://console.upstash.com -> Create Database -> REST API
# Sem essas vars, o historico cai para arquivo local (apenas desenvolvimento)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Worker
# Intervalo de analise em milissegundos (padrao: 60000 = 1 minuto)
# Em desenvolvimento local pode usar 5000 (5s)
WORKER_INTERVAL_MS=60000

# Web (Vite - usado apenas em tempo de build)
# Em desenvolvimento: deixar vazio (usa /api como proxy do Vite)
# Em producao (Render): URL publica da API
VITE_API_URL=
