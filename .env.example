# API
PORT=3001
NODE_ENV=development

# Upstash Redis (production)
# Get credentials at: https://console.upstash.com -> Create Database -> REST API
# Without these vars, storage falls back to local JSON files
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI market commentary
ANTHROPIC_API_KEY=

# Binance credentials
# Testnet keys: https://testnet.binance.vision
# Production keys: https://www.binance.com/en/my/settings/api-management
# Recommended: restrict API key to "Spot trading" only, disable withdrawals
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Execution mode: simulation | live
# simulation = signals only, no orders placed
# live = executes real orders on Binance
EXECUTION_MODE=simulation

# Risk management
TRADE_AMOUNT_USDT=50
MAX_OPEN_TRADES=2
STOP_LOSS_PCT=0.03
TAKE_PROFIT_PCT=0.05

# Worker interval in milliseconds (default: 60000 = 1 minute)
WORKER_INTERVAL_MS=60000

# Web (Vite - build time only)
# Development: leave empty (Vite proxy handles /api)
# Production (Render): public API URL
VITE_API_URL=
