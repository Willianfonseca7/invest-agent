# API
PORT=3001
NODE_ENV=development

# Caminho para o arquivo de historico (opcional)
# Em producao: definido automaticamente pelo render.yaml ou docker-compose
# Em desenvolvimento: resolve para /data/history.json na raiz do projeto
DATA_DIR=

# Web (Vite - usado apenas em tempo de build)
# Em desenvolvimento: deixar vazio (usa /api como proxy do Vite)
# Em producao (Render): URL publica da API ex: https://invest-agent-api.onrender.com
VITE_API_URL=
